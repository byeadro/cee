# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/

# Secrets and local config (defense-in-depth; user-config files live at
# ~/.cee/ outside the repo, but belt-and-braces guards against accidental
# git add of any local copy)
.env
*.env
credentials.toml
config.toml
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# CEE-specific (user state, runtime artifacts)
# DO commit: ~/cee/runs/golden/ (test fixtures)
# DO NOT commit: ~/cee/runs/* (real Run state)
runs/*
!runs/golden/
!runs/golden/**
audit/
bible/.sync_meta.json
promotion_queue.json

# Build artifacts (regenerated on boot per bible 04 §6.5;
# never hand-edited, never source-of-truth)
skills/index.json
.claude/agents/index.json

# IDE
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db
# Python packaging
*.egg-info/
build/
dist/
